APP_NAME=MatsyaLink AI
APP_ENV=development
APP_TIMEZONE=Asia/Kolkata

# ISO-4217 currency code shown in decision explanations and email templates.
CURRENCY_CODE=INR

# ---------------------------------------------------------------------------
# Gemma 4 31B Cloud reasoning through Ollama.
# Local Ollama proxy mode: run `ollama signin`, then `ollama pull gemma4:31b-cloud`.
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma4:31b-cloud

# ---------------------------------------------------------------------------
# Google Sheets prototype database.
USE_GOOGLE_SHEETS=false
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
# Alternative for hosted deployments: one-line service account JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Sheet tab names (must match your workbook exactly).
MARKET_SHEET_NAME=Market Prices
BUYERS_SHEET_NAME=Buyers
TRANSACTIONS_SHEET_NAME=Transactions

# ---------------------------------------------------------------------------
# Gmail SMTP. Use a Google app password, not an account password.
EMAIL_DRY_RUN=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TIMEOUT_SEC=20
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=

# ---------------------------------------------------------------------------
# Freshness classification thresholds (hours since catch time).
# Catch age <= FRESHNESS_FRESH_HOURS   → Fresh
# Catch age <= FRESHNESS_MODERATE_HOURS → Moderate
# Catch age >  FRESHNESS_MODERATE_HOURS → Low Freshness
FRESHNESS_FRESH_HOURS=6.0
FRESHNESS_MODERATE_HOURS=12.0

# ---------------------------------------------------------------------------
# Urgency classification thresholds (quantity in kg).
# quantity >= URGENCY_HIGH_QTY_KG OR freshness=Low  → High urgency
# quantity >= URGENCY_MEDIUM_QTY_KG OR freshness=Mod → Medium urgency
URGENCY_HIGH_QTY_KG=750.0
URGENCY_MEDIUM_QTY_KG=300.0

# ---------------------------------------------------------------------------
# Buyer scoring weights — MUST sum to exactly 1.0.
# The app raises a ValueError on startup if this constraint is violated.
SCORE_WEIGHT_PRICE=0.35
SCORE_WEIGHT_DISTANCE=0.25
SCORE_WEIGHT_DEMAND=0.20
SCORE_WEIGHT_CAPACITY=0.10
SCORE_WEIGHT_FRESHNESS=0.10

# Demand-level component scores (0–100).
SCORE_DEMAND_HIGH=100.0
SCORE_DEMAND_MEDIUM=65.0
SCORE_DEMAND_LOW=25.0

# Score awarded when catch freshness is one grade below the buyer's requirement.
FRESHNESS_PARTIAL_SCORE=40.0
