APP_NAME=MatsyaLink AI
APP_ENV=development
APP_TIMEZONE=Asia/Kolkata

# Gemini structured reasoning. Keep disabled for deterministic/offline demos.
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Sheets prototype database.
USE_GOOGLE_SHEETS=false
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
# Alternative for hosted deployments: one-line service account JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Gmail SMTP. Use a Google app password, not an account password.
EMAIL_DRY_RUN=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
